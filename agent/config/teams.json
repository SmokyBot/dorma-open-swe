{
  "defaults": {
    "llm_provider": "anthropic",
    "llm_model": "claude-sonnet-4-20250514",
    "max_diff_lines": 5000,
    "max_review_agents": 6,
    "min_review_agents": 2,
    "excluded_paths": [
      "**/generated/**",
      "**/node_modules/**",
      "**/*.min.js",
      "**/*.min.css",
      "**/package-lock.json",
      "**/yarn.lock",
      "**/pnpm-lock.yaml"
    ]
  },
  "teams": {
    "example-team": {
      "name": "Example Team",
      "bitbucket_projects": ["PROJ"],
      "bitbucket_repos": ["PROJ/my-repo"],
      "mcp_token_env": "EXAMPLE_TEAM_MCP_TOKEN",
      "review_config": {
        "custom_review_instructions": "",
        "excluded_paths": [],
        "max_diff_lines": 5000
      }
    }
  }
}
